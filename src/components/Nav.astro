---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services & Pricing' },
  { href: '/hubspot-revops-consultant/', label: 'HubSpot RevOps' },
  { href: '/fractional-cro/', label: 'Fractional CRO' },
  { href: '/about/', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="OrangeCore Group home">
      <span class="brand-mark"></span>
      <span class="brand-name"><strong>Orange</strong>Core Group</span>
    </a>

    <div class="nav-links" id="nav-links">
      {navLinks.slice(1).map(({ href, label }) => (
        <a href={href} class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}>
          {label}
        </a>
      ))}
    </div>

    <a href="/contact/" class="nav-cta">Book a call</a>

    <button class="hamburger" id="nav-toggle" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="nav-mobile">
    {navLinks.map(({ href, label }) => (
      <a href={href} class="nav-mobile-link">{label}</a>
    ))}
    <a href="/contact/" class="nav-mobile-cta">Book a discovery call →</a>
  </div>
</nav>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-mobile')?.classList.toggle('open');
    document.getElementById('nav-toggle')?.classList.toggle('open');
  });
</script>

<style>
  .site-nav {
    background: #1A1714;
    border-bottom: 1px solid #2D2620;
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .nav-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand-mark {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: #C2511A;
    position: relative;
    flex-shrink: 0;
  }
  .brand-mark::after {
    content: '';
    position: absolute; inset: 6px;
    border-radius: 50%;
    background: #1A1714;
  }
  .brand-mark::before {
    content: '';
    position: absolute; inset: 10px;
    border-radius: 50%;
    background: #C2511A;
  }
  .brand-name {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px;
    font-weight: 400;
    color: #F4EFE7;
    letter-spacing: -0.01em;
  }
  .brand-name strong {
    font-weight: 700;
    font-family: 'Inter Tight', sans-serif;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: flex-end;
  }
  .nav-link {
    font-family: 'Inter Tight', sans-serif;
    font-size: 13.5px;
    color: #6B6258;
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 3px;
    transition: color .15s;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link.active { color: #C8C4BF; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    background: #C2511A;
    color: #fff;
    padding: 9px 18px;
    border-radius: 4px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    transition: background .15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav-cta:hover { background: #A3430F; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
  }
  .hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: #C8C4BF;
    border-radius: 2px;
    transition: transform .2s, opacity .2s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    display: none;
    flex-direction: column;
    border-top: 1px solid #2D2620;
    padding: 1rem 32px 1.5rem;
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile-link {
    font-family: 'Inter Tight', sans-serif;
    font-size: 15px;
    color: #9A9080;
    text-decoration: none;
    padding: 11px 0;
    border-bottom: 1px solid #2D2620;
    transition: color .15s;
  }
  .nav-mobile-link:hover { color: #F4EFE7; }
  .nav-mobile-cta {
    margin-top: 16px;
    background: #C2511A;
    color: #fff;
    padding: 13px 20px;
    border-radius: 4px;
    text-align: center;
    font-family: 'Inter Tight', sans-serif;
    font-weight: 600;
    font-size: 14.5px;
    text-decoration: none;
    border: none;
  }

  @media (max-width: 900px) {
    .hamburger { display: flex; }
    .nav-cta { display: none; }
    .nav-links .nav-link { display: none; }
  }
</style>
