---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services & Pricing' },
  { href: '/hubspot-revops-consultant/', label: 'HubSpot RevOps' },
  { href: '/fractional-cro/', label: 'Fractional CRO' },
  { href: '/about/', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-row">
    <a href="/" class="brand" aria-label="OrangeCore Group home">
      <span class="brand-mark"></span>
      <span><b>Orange</b>Core Group</span>
    </a>

    <div class="nav-links">
      {navLinks.slice(1).map(({ href, label }) => (
        <a
          href={href}
          class:list={[{ 'is-active': currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
        >
          {label}
        </a>
      ))}
      <a href="/contact/" class="btn btn-nav">Book a call</a>
    </div>

    <button class="nav-hamburger" id="nav-toggle" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="nav-mobile">
    {navLinks.map(({ href, label }) => (
      <a href={href}>{label}</a>
    ))}
    <a href="/contact/" class="btn btn-nav-mobile">Book a discovery call →</a>
  </div>
</nav>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-mobile')?.classList.toggle('open');
    document.getElementById('nav-toggle')?.classList.toggle('open');
  });
</script>

<style>
  :root {
    --paper: #F4EFE7;
    --ink: #1A1714;
    --ink-2: #3A332C;
    --ink-3: #6B6258;
    --rule-soft: #D9D0BE;
    --accent: #C2511A;
    --serif: 'Source Serif 4', Georgia, serif;
    --sans: 'Inter Tight', 'Helvetica Neue', Arial, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: color-mix(in oklab, var(--paper) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--rule-soft);
  }

  .nav-row {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--serif);
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  .brand b { font-weight: 600; font-family: var(--sans); }

  .brand-mark {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent);
    position: relative;
    flex-shrink: 0;
  }
  .brand-mark::after {
    content: '';
    position: absolute; inset: 5px;
    border-radius: 50%;
    background: var(--paper);
  }
  .brand-mark::before {
    content: '';
    position: absolute; inset: 9px;
    border-radius: 50%;
    background: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-links a {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink-2);
    text-decoration: none;
    transition: color .15s;
  }
  .nav-links a:hover, .nav-links a.is-active { color: var(--ink); }

  .btn-nav {
    background: var(--ink);
    color: var(--paper) !important;
    padding: 9px 18px;
    border-radius: 999px;
    font-size: 13.5px !important;
    font-weight: 500;
    transition: background .15s !important;
  }
  .btn-nav:hover { background: #000 !important; color: var(--paper) !important; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav-hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform .2s, opacity .2s;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--rule-soft);
    padding: 1rem 32px 1.5rem;
    gap: 0;
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile a {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink-2);
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .nav-mobile a:last-child { border-bottom: none; }
  .btn-nav-mobile {
    margin-top: 12px;
    background: var(--ink);
    color: var(--paper) !important;
    padding: 12px 20px;
    border-radius: 999px;
    text-align: center;
    font-weight: 500;
    border: none !important;
  }

  @media (max-width: 900px) {
    .nav-hamburger { display: flex; }
    .nav-links a:not(.btn-nav) { display: none; }
    .btn-nav { display: none; }
  }
</style>
