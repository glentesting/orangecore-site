---
import Base from '../../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fractional CRO Services",
  "provider": { "@type": "Person", "name": "Glen Swindell", "jobTitle": "Fractional Chief Revenue Officer" },
  "areaServed": ["Plano TX", "Dallas TX", "DFW", "United States"],
  "description": "Fractional Chief Revenue Officer services for B2B SaaS and fintech companies. 10+ years revenue leadership."
};
---

<Base
  title="Fractional CRO for B2B SaaS & Fintech | OrangeCore Group | Plano, TX"
  description="Glen Swindell is a fractional Chief Revenue Officer serving B2B SaaS and fintech companies. 10+ years revenue leadership. Fixed-fee, defined deliverables."
  schema={schema}
>

  <header class="page-header">
    <div class="wrap">
      <div class="header-meta">
        <span class="eyebrow">Fractional CRO</span>
        <span class="meta-text">— Plano, TX & Remote</span>
      </div>
      <h1 class="display page-h1">
        Fractional Chief Revenue Officer<br>
        for B2B SaaS and<br>
        <em class="accent-ital">Fintech Companies.</em>
      </h1>
      <p class="lede page-lede">
        Ten-plus years of revenue leadership, without the $250K salary attached to it.
        Fintech and payments background. Army veteran discipline. Fixed scope —
        so you know exactly what you're getting before anything starts.
      </p>
      <div style="display:flex;gap:12px;margin-top:32px;flex-wrap:wrap;">
        <a href="/contact/" class="btn btn-primary">Book a discovery call <span class="arr">→</span></a>
        <a href="/services/#operate" class="btn btn-ghost">Operate tier — $7,500/mo <span class="arr">→</span></a>
      </div>
    </div>
  </header>

  <hr class="rule" />

  <!-- WHAT THEY GET -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">What a fractional CRO actually does</span>
        <h2 class="display sec-h2">Not strategy decks.<br><em class="accent-ital">Actual revenue work.</em></h2>
      </div>
      <div class="what-grid">
        <div class="what-card">
          <h3 class="what-h">Pipeline & Forecast</h3>
          <p class="what-p">Monthly pipeline reviews with leadership. Stage-weighted forecasting that's actually defensible. Reps held to a process, not gut feeling.</p>
        </div>
        <div class="what-card">
          <h3 class="what-h">Sales Playbook</h3>
          <p class="what-p">Talk tracks, objection handling, discovery frameworks — built for your specific ICP. Not a template from a generalist who's never touched your vertical.</p>
        </div>
        <div class="what-card">
          <h3 class="what-h">RevOps & CRM</h3>
          <p class="what-p">HubSpot, Salesforce, or Pipedrive configured to match your actual sales motion. Data you can trust. Dashboards leadership will actually open.</p>
        </div>
        <div class="what-card">
          <h3 class="what-h">Go-to-Market Alignment</h3>
          <p class="what-p">Marketing and sales working off the same definition of a qualified lead. Handoff process documented. No more "marketing sends us garbage" conversations.</p>
        </div>
        <div class="what-card">
          <h3 class="what-h">Team Coaching</h3>
          <p class="what-p">Bi-weekly coaching sessions with the sales team. Pattern recognition from working across B2B SaaS, fintech, and payments — not generic sales methodology.</p>
        </div>
        <div class="what-card">
          <h3 class="what-h">Board & Investor Prep</h3>
          <p class="what-p">Revenue narrative, pipeline story, forecast model — built for the board meeting or fundraise, not assembled the night before.</p>
        </div>
      </div>
      <p class="ai-callout">Every engagement is AI-augmented. Deliverables are more thorough, documentation is more complete, and turnaround is faster — without cutting corners on the thinking behind it.</p>
    </div>
  </section>

  <hr class="rule" />

  <!-- HIRING SIGNALS -->
  <section class="section section-dark">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow" style="color:#B7AC9C;">When to hire one</span>
        <h2 class="display sec-h2" style="color:var(--paper);">Five signals it's time<br><em class="accent-ital">to bring in a fractional CRO.</em></h2>
        <p class="lede" style="color:#C9C0B2;margin-top:14px;max-width:52ch;">Most companies wait too long. If you're recognizing more than two of these, it's probably time.</p>
      </div>
      <div class="signals">
        <div class="signal">
          <span class="signal-n">01</span>
          <div>
            <p class="signal-h">Revenue is inconsistent — and nobody knows why</p>
            <p class="signal-p">Good quarter, bad quarter, no real explanation for either. That's a process problem, not a market problem.</p>
          </div>
        </div>
        <div class="signal">
          <span class="signal-n">02</span>
          <div>
            <p class="signal-h">The CEO is still running revenue</p>
            <p class="signal-p">At some point this stops scaling. If the founder is still the de facto CRO, something needs to change before the next growth phase.</p>
          </div>
        </div>
        <div class="signal">
          <span class="signal-n">03</span>
          <div>
            <p class="signal-h">You just hired a sales team</p>
            <p class="signal-p">Reps without a playbook, process, or pipeline structure will figure it out on their own — and the results will be variable at best.</p>
          </div>
        </div>
        <div class="signal">
          <span class="signal-n">04</span>
          <div>
            <p class="signal-h">You're prepping for a Series A or B</p>
            <p class="signal-p">Investors want to see a repeatable revenue motion. If your pipeline and forecast aren't board-ready, that conversation is going to be uncomfortable.</p>
          </div>
        </div>
        <div class="signal">
          <span class="signal-n">05</span>
          <div>
            <p class="signal-h">A full-time CRO isn't in the budget yet</p>
            <p class="signal-p">A qualified CRO runs $200K–$300K in salary. Fractional gives you the thinking and output at a fraction of the cost — with defined scope, not an open-ended engagement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFFERENTIATORS -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">What makes this different</span>
        <h2 class="display sec-h2">Depth, not breadth.</h2>
      </div>
      <div class="diff-grid">
        <div class="diff">
          <h3 class="diff-h">Payments & Fintech</h3>
          <p class="diff-p">Interchange economics, tokenization, BNPL infrastructure, enterprise procurement in financial services — this isn't a talking point, it's actual background. If your buyers include bank risk committees or enterprise procurement in regulated industries, that context matters. Most generalist consultants don't have it.</p>
        </div>
        <div class="diff">
          <h3 class="diff-h">Army Veteran</h3>
          <p class="diff-p">Eight years in the U.S. Army (2010–2018). Discipline, systems thinking, people-first leadership — these carry directly into how revenue operations runs. Processes get documented. Timelines get met. The work gets done.</p>
        </div>
        <div class="diff">
          <h3 class="diff-h">Productized, Not Open-Ended</h3>
          <p class="diff-p">Most fractional consultants charge hourly and let scope expand. Every OrangeCore engagement has defined deliverables, defined timelines, and a defined end. You know exactly what you're getting before anything starts.</p>
        </div>
        <div class="diff">
          <h3 class="diff-h">Based in Plano, TX</h3>
          <p class="diff-p">Local to the DFW market. Available for in-person work when it matters. National clients served remotely — same deliverables, same accountability, same timeline regardless of geography.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- PRICING -->
  <section class="section section-band">
    <div class="wrap">
      <div class="price-block">
        <div>
          <span class="eyebrow">The Operate Tier</span>
          <h2 class="display price-h2">Fractional CRO starts<br><em class="accent-ital">at $7,500/mo.</em></h2>
          <p class="body-copy" style="margin-top:20px;">3-month minimum. Deliverables defined at kickoff — not left open-ended. Monthly pipeline review, one major deliverable per month, bi-weekly coaching, async Slack access.</p>
          <p class="body-copy" style="margin-top:14px;color:var(--ink-3);">For a one-time project (playbook, GTM strategy, board prep), see the Build tier or Add-ons on the services page.</p>
          <div style="display:flex;gap:12px;margin-top:28px;flex-wrap:wrap;">
            <a href="/contact/" class="btn btn-primary">Book a discovery call</a>
            <a href="/services/" class="btn btn-ghost">Full pricing →</a>
          </div>
        </div>
        <div class="price-display">
          <div class="price-num">$7,500</div>
          <div class="price-per">/mo</div>
          <div class="price-note">3-month minimum</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head" style="margin-bottom:48px;">
        <span class="eyebrow">Common questions</span>
        <h2 class="display sec-h2">Fractional CRO questions<br><em class="accent-ital">we hear a lot.</em></h2>
      </div>
      <div class="faq">
        <details>
          <summary>What's the difference between a fractional CRO and a sales consultant?</summary>
          <p>A sales consultant comes in for a specific project — a playbook, a training, a process doc. A fractional CRO operates at the strategic level on an ongoing basis: pipeline, forecast, team coaching, GTM alignment, board prep. Different scope, different relationship.</p>
        </details>
        <details>
          <summary>How long until we see results?</summary>
          <p>Depends on what's broken. Pipeline clarity and CRM cleanup show results in weeks. Consistent revenue improvement takes a quarter to show up in the numbers. Anyone promising faster than that is selling you something.</p>
        </details>
        <details>
          <summary>Do you work with companies outside DFW?</summary>
          <p>Yes — most clients are remote. Based in Plano, TX and available for in-person meetings in the DFW area, but the work doesn't require it. Same deliverables, same accountability regardless of location.</p>
        </details>
        <details>
          <summary>What CRMs do you work in?</summary>
          <p>HubSpot is the primary platform. Also experienced in Salesforce and Pipedrive. If you're on something else, let's talk about it during discovery.</p>
        </details>
        <details>
          <summary>What if we need a full-time CRO eventually?</summary>
          <p>That's actually the goal. Operate is designed to hold the line and build the function so a full-time hire walks into something running, not on fire. We'll help you build the scorecard to hire the right person.</p>
        </details>
        <details>
          <summary>Is this right for early-stage companies?</summary>
          <p>The sweet spot is post-Series A or bootstrapped with real revenue. Pre-revenue, you likely don't need a fractional CRO — you need product-market fit first. Foundation might be a better starting point if you're not sure.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="section section-dark">
    <div class="wrap cta-wrap">
      <span class="eyebrow">Plano, TX · Serving DFW and national clients</span>
      <h2 class="display cta-h2">Think this might<br><em class="accent-ital">be the right fit?</em></h2>
      <p class="lede" style="color:#C9C0B2;max-width:52ch;">30 minutes. We'll figure out together if a fractional CRO engagement makes sense — and if it doesn't, you'll hear that too.</p>
      <div style="display:flex;gap:14px;margin-top:32px;flex-wrap:wrap;">
        <a href="/contact/" class="btn" style="background:var(--paper);color:var(--ink);">Book a discovery call <span class="arr">→</span></a>
        <a href="/#diagnostic" class="btn" style="color:var(--paper);border:1px solid #4D453C;">Take the diagnostic first</a>
      </div>
    </div>
  </section>

</Base>

<style>
  :root {
    --paper:#F4EFE7; --paper-2:#EBE4D7; --paper-3:#E2D9C8;
    --ink:#1A1714; --ink-2:#3A332C; --ink-3:#6B6258;
    --rule:#C9BFAD; --rule-soft:#D9D0BE; --accent:#C2511A;
    --serif:'Source Serif 4',Georgia,serif;
    --sans:'Inter Tight','Helvetica Neue',Arial,sans-serif;
    --mono:'JetBrains Mono',monospace;
  }
  :global(body){background:var(--paper)!important;color:var(--ink)!important;font-family:var(--sans)!important;}
  .wrap{max-width:1240px;margin:0 auto;padding:0 32px;}
  .rule{height:1px;background:var(--rule);border:0;margin:0;}
  .section{padding:96px 0;}
  .section-band{background:var(--paper-2);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);}
  .section-dark{background:var(--ink);color:var(--paper);}
  .section-dark .eyebrow{color:#B7AC9C;}
  .display{font-family:var(--serif);font-weight:400;letter-spacing:-0.022em;line-height:0.98;color:var(--ink);}
  .accent-ital{font-style:italic;color:var(--accent);font-family:var(--serif);}
  .lede{font-family:var(--serif);font-size:21px;line-height:1.45;color:var(--ink-2);letter-spacing:-0.005em;}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3);}
  .meta-text{font-family:var(--mono);font-size:12.5px;letter-spacing:0.04em;color:var(--ink-3);}
  .btn{display:inline-flex;align-items:center;gap:10px;padding:13px 20px;border-radius:999px;font-size:14.5px;font-weight:500;border:1px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-decoration:none;font-family:var(--sans);}
  .btn-primary{background:var(--ink);color:var(--paper);}
  .btn-primary:hover{background:#000;}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink);}
  .btn-ghost:hover{background:var(--ink);color:var(--paper);}
  .arr{display:inline-block;transition:transform .2s;}
  .btn:hover .arr{transform:translateX(3px);}
  .page-header{padding:64px 0 56px;}
  .header-meta{display:flex;align-items:baseline;gap:18px;margin-bottom:28px;flex-wrap:wrap;}
  .page-h1{font-size:clamp(42px,5.5vw,84px);letter-spacing:-0.022em;line-height:0.98;max-width:16ch;}
  .page-lede{margin-top:24px;max-width:58ch;}
  .sec-head{margin-bottom:56px;}
  .sec-h2{font-size:clamp(38px,4.6vw,64px);letter-spacing:-0.02em;line-height:1.02;margin-top:14px;}
  .what-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--rule);border:1px solid var(--rule);margin-bottom:28px;}
  .what-card{background:var(--paper);padding:28px 24px;}
  .what-h{font-family:var(--serif);font-size:18px;letter-spacing:-0.01em;color:var(--ink);margin-bottom:10px;}
  .what-p{font-size:13.5px;color:var(--ink-2);line-height:1.65;}
  .ai-callout{font-size:13.5px;color:var(--accent);background:color-mix(in oklab,var(--accent) 8%,var(--paper));border:1px solid color-mix(in oklab,var(--accent) 20%,var(--paper));border-radius:6px;padding:12px 16px;line-height:1.6;max-width:700px;}
  .signals{display:flex;flex-direction:column;border-top:1px solid #2D2620;}
  .signal{display:flex;gap:28px;padding:28px 0;border-bottom:1px solid #2D2620;align-items:flex-start;}
  .signal:last-child{border-bottom:none;}
  .signal-n{font-family:var(--mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8A8073;flex-shrink:0;min-width:28px;padding-top:3px;}
  .signal-h{font-family:var(--serif);font-size:19px;letter-spacing:-0.01em;color:var(--paper);margin-bottom:6px;}
  .signal-p{font-size:14px;color:#8A8073;line-height:1.65;}
  .diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem 4rem;}
  .diff-h{font-family:var(--serif);font-size:20px;letter-spacing:-0.01em;color:var(--ink);margin-bottom:10px;}
  .diff-p{font-size:14px;color:var(--ink-2);line-height:1.65;}
  .body-copy{font-size:15.5px;color:var(--ink-2);line-height:1.7;}
  .price-block{display:grid;grid-template-columns:1fr auto;gap:64px;align-items:center;}
  .price-h2{font-size:clamp(38px,4.6vw,60px);letter-spacing:-0.022em;line-height:1;margin-top:14px;}
  .price-display{text-align:center;padding:32px;border:1px solid var(--rule);background:var(--paper);}
  .price-num{font-family:var(--serif);font-size:56px;letter-spacing:-0.03em;line-height:1;color:var(--ink);}
  .price-per{font-family:var(--serif);font-size:24px;color:var(--ink-3);}
  .price-note{font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-3);margin-top:8px;}
  .faq{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--rule);}
  .faq details{padding:24px 0;border-bottom:1px solid var(--rule);}
  .faq details:nth-child(even){padding-left:32px;border-left:1px solid var(--rule);}
  .faq details:nth-child(odd){padding-right:32px;}
  .faq summary{list-style:none;cursor:pointer;font-family:var(--serif);font-size:19px;letter-spacing:-0.01em;color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:16px;}
  .faq summary::-webkit-details-marker{display:none;}
  .faq summary::after{content:'+';font-family:var(--sans);font-size:22px;color:var(--ink-3);font-weight:300;transition:transform .2s;flex-shrink:0;}
  .faq details[open] summary::after{transform:rotate(45deg);}
  .faq details p{margin:14px 0 0;color:var(--ink-2);font-size:15px;line-height:1.65;max-width:52ch;}
  .cta-wrap{padding:40px 0;}
  .cta-h2{font-size:clamp(48px,6vw,88px);max-width:14ch;margin:18px 0 24px;color:var(--paper);}
  .section-dark .display{color:var(--paper);}
  @media(max-width:1000px){
    .what-grid{grid-template-columns:1fr 1fr;}
    .diff-grid{grid-template-columns:1fr;gap:2rem;}
    .price-block{grid-template-columns:1fr;gap:32px;}
    .price-display{text-align:left;}
    .faq{grid-template-columns:1fr;}
    .faq details:nth-child(even){padding-left:0;border-left:none;}
    .faq details:nth-child(odd){padding-right:0;}
  }
  @media(max-width:640px){
    .wrap{padding:0 20px;}
    .section{padding:64px 0;}
    .what-grid{grid-template-columns:1fr;}
  }
</style>
