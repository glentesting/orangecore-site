---
import Base from '../../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "HubSpot RevOps Consulting",
  "provider": { "@type": "Organization", "name": "OrangeCore Group" },
  "areaServed": ["Dallas TX", "Plano TX", "DFW", "United States"],
  "description": "HubSpot CRM buildouts, pipeline configuration, workflow automation, and data cleanup for B2B SaaS and fintech teams."
};
---

<Base
  title="HubSpot RevOps Consultant | CRM Buildout & Pipeline Setup | OrangeCore Group"
  description="Expert HubSpot RevOps consulting — full CRM buildouts, pipeline configuration, workflow automation, and data cleanup for B2B SaaS and fintech teams. Based in DFW."
  schema={schema}
>

  <header class="page-header">
    <div class="wrap">
      <div class="header-meta">
        <span class="eyebrow">HubSpot RevOps</span>
        <span class="meta-text">— DFW & Remote</span>
      </div>
      <h1 class="display page-h1">
        HubSpot RevOps Consulting —<br>
        <em class="accent-ital">Buildouts, Pipeline Setup</em><br>
        & CRM Cleanup.
      </h1>
      <p class="lede page-lede">
        Most HubSpot setups look like they were built in a hurry and never revisited.
        Bad data, broken workflows, pipelines nobody trusts. We fix that — and build it
        in a way your team will actually use.
      </p>
      <div style="display:flex;gap:12px;margin-top:32px;flex-wrap:wrap;">
        <a href="/contact/" class="btn btn-primary">Book a discovery call <span class="arr">→</span></a>
        <a href="/services/" class="btn btn-ghost">See pricing <span class="arr">→</span></a>
      </div>
    </div>
  </header>

  <hr class="rule" />

  <!-- WHAT'S INCLUDED -->
  <section class="section">
    <div class="wrap">
      <div class="two-col">
        <div>
          <span class="eyebrow">What a proper buildout includes</span>
          <h2 class="display col-h2">More than just<br><em class="accent-ital">turning it on.</em></h2>
          <p class="body-copy">A lot of companies have HubSpot. Very few have it set up in a way that reflects how their sales team actually works. Here's what a real buildout covers:</p>
          <ul class="feature-list">
            <li>Custom properties configured to match your actual deal data</li>
            <li>Pipeline stages with defined entry and exit criteria — not guesswork</li>
            <li>Workflow automation that handles the repetitive stuff automatically</li>
            <li>Lead scoring built around your ICP, not HubSpot's defaults</li>
            <li>Reporting dashboards showing metrics leadership actually opens</li>
            <li>Marketing-to-sales handoff configured and documented</li>
            <li>Data cleanup — duplicate records, dead contacts, garbage fields</li>
          </ul>
          <p class="ai-callout">Every buildout is AI-augmented. The audit moves faster, documentation is more complete, and the gap analysis catches things a manual review would miss.</p>
        </div>
        <div>
          <div class="problems-card">
            <p class="eyebrow" style="margin-bottom:20px;">Common problems we fix</p>
            <div class="problem">
              <span class="problem-x">✗</span>
              <div>
                <p class="problem-title">Bad data nobody trusts</p>
                <p class="problem-desc">Reps stopped logging activity because the CRM doesn't reflect reality. We clean it up and set hygiene rules that keep it clean going forward.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem-x">✗</span>
              <div>
                <p class="problem-title">No real pipeline structure</p>
                <p class="problem-desc">Stages created in a rush, never updated. Deals sit in "Proposal Sent" for months. We fix the stage definitions and the process behind them.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem-x">✗</span>
              <div>
                <p class="problem-title">Missing or broken workflows</p>
                <p class="problem-desc">Manual tasks that should be automated, sequences that go nowhere. We audit all of it and rebuild what matters.</p>
              </div>
            </div>
            <div class="problem">
              <span class="problem-x">✗</span>
              <div>
                <p class="problem-title">Zero useful reporting</p>
                <p class="problem-desc">Dashboards that exist but don't answer the questions leadership is actually asking. We build reports that connect to real revenue decisions.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- PROCESS -->
  <section class="section section-band">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">The process</span>
        <h2 class="display sec-h2">Start to finish,<br><em class="accent-ital">no surprises.</em></h2>
      </div>
      <div class="process">
        <div class="process-step">
          <span class="step-n">01</span>
          <div>
            <h3 class="step-h">Intake & Discovery</h3>
            <p class="step-p">Day one. Structured session covering your current HubSpot setup, your sales process, and where things are breaking. Not open-ended — this takes one working session.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-n">02</span>
          <div>
            <h3 class="step-h">Audit & Gap Analysis</h3>
            <p class="step-p">We document everything broken, missing, or misaligned — and prioritize it. You know exactly what the problems are before anything gets built.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-n">03</span>
          <div>
            <h3 class="step-h">Build</h3>
            <p class="step-p">CRM reconfiguration, pipeline setup, workflow automation, property cleanup, dashboard creation. Built to your specific sales motion, not a template.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-n">04</span>
          <div>
            <h3 class="step-h">Handoff & Documentation</h3>
            <p class="step-p">Full walkthrough of what was built and why, plus documentation your team can reference. Nothing lives only in someone's head.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-n">05</span>
          <div>
            <h3 class="step-h">30-Day Support</h3>
            <p class="step-p">Build engagements include 30 days of Slack access post-delivery. Questions, tweaks, second opinions — until the team is using it confidently.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING BLOCK -->
  <section class="section">
    <div class="wrap">
      <div class="pricing-block">
        <div>
          <span class="eyebrow">Pricing</span>
          <h2 class="display pricing-h2">HubSpot RevOps<br><em class="accent-ital">starts at $5,500.</em></h2>
          <p class="body-copy" style="margin-top:20px;">Foundation audit is $5,500 and delivers in 10 business days. Full Build is $14,500 and runs 3–4 weeks. Both are flat-fee — no hourly billing, no budget surprises.</p>
          <div style="display:flex;gap:12px;margin-top:28px;flex-wrap:wrap;">
            <a href="/services/" class="btn btn-ghost">See full pricing <span class="arr">→</span></a>
            <a href="/contact/" class="btn btn-primary">Book a discovery call</a>
          </div>
        </div>
        <div class="pricing-ledger">
          <div>
            <div class="k">Foundation</div>
            <div class="v">$5,500</div>
            <div class="sub">10 business days</div>
          </div>
          <div>
            <div class="k">Build</div>
            <div class="v">$14,500</div>
            <div class="sub">3–4 weeks</div>
          </div>
          <div>
            <div class="k">Operate</div>
            <div class="v">$7,500<span class="v-sub">/mo</span></div>
            <div class="sub">Ongoing support</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- FAQ -->
  <section class="section section-band">
    <div class="wrap">
      <div class="sec-head" style="margin-bottom:48px;">
        <span class="eyebrow">Common questions</span>
        <h2 class="display sec-h2">HubSpot questions<br><em class="accent-ital">we hear a lot.</em></h2>
      </div>
      <div class="faq">
        <details>
          <summary>How long does a HubSpot buildout take?</summary>
          <p>A full Build runs 3–4 weeks. Foundation audits deliver in 10 business days. Timeline depends on how much cleanup is needed before building starts.</p>
        </details>
        <details>
          <summary>What if we're migrating from Salesforce?</summary>
          <p>Migrations are handled as part of the Build engagement or as a standalone add-on ($4,500). Data mapping, import, custom property recreation, and workflow rebuilds all included.</p>
        </details>
        <details>
          <summary>Do you train the team after the buildout?</summary>
          <p>Yes. Every Build includes a handoff session and documentation. The 30-day post-delivery support window is for questions, tweaks, and making sure the team is actually using what was built.</p>
        </details>
        <details>
          <summary>We already have HubSpot — can you just fix what's broken?</summary>
          <p>That's actually more common than a greenfield build. Start with Foundation — it identifies exactly what's broken and gives you a prioritized fix list. Then decide if you want to handle it or bring us in.</p>
        </details>
        <details>
          <summary>Do you work with HubSpot for SaaS companies specifically?</summary>
          <p>Yes. SaaS and fintech are the primary verticals — familiarity with product-led growth motions, trial conversion tracking, expansion revenue, and the HubSpot configurations that support them.</p>
        </details>
        <details>
          <summary>Which HubSpot hubs do you cover?</summary>
          <p>Sales Hub, Marketing Hub, and Operations Hub. If your setup involves Service Hub, we can work with that too. The goal is always that you own a system that runs without us.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="section section-dark">
    <div class="wrap cta-wrap">
      <span class="eyebrow">Based in DFW · Serving clients nationwide</span>
      <h2 class="display cta-h2">Ready to actually<br><em class="accent-ital">fix your HubSpot?</em></h2>
      <p class="lede" style="color:#C9C0B2;max-width:52ch;">30 minutes. No pitch, no pressure. We'll look at where things are and tell you honestly what it would take to get them right.</p>
      <div style="display:flex;gap:14px;margin-top:32px;flex-wrap:wrap;">
        <a href="/contact/" class="btn" style="background:var(--paper);color:var(--ink);">Book a discovery call <span class="arr">→</span></a>
        <a href="/services/" class="btn" style="color:var(--paper);border:1px solid #4D453C;">See pricing</a>
      </div>
    </div>
  </section>

</Base>

<style>
  :root {
    --paper:#F4EFE7; --paper-2:#EBE4D7; --paper-3:#E2D9C8;
    --ink:#1A1714; --ink-2:#3A332C; --ink-3:#6B6258;
    --rule:#C9BFAD; --rule-soft:#D9D0BE; --accent:#C2511A;
    --serif:'Source Serif 4',Georgia,serif;
    --sans:'Inter Tight','Helvetica Neue',Arial,sans-serif;
    --mono:'JetBrains Mono',monospace;
  }
  :global(body){background:var(--paper)!important;color:var(--ink)!important;font-family:var(--sans)!important;}
  .wrap{max-width:1240px;margin:0 auto;padding:0 32px;}
  .rule{height:1px;background:var(--rule);border:0;margin:0;}
  .section{padding:96px 0;}
  .section-band{background:var(--paper-2);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);}
  .section-dark{background:var(--ink);color:var(--paper);}
  .section-dark .eyebrow{color:#B7AC9C;}
  .section-dark .display{color:var(--paper);}
  .display{font-family:var(--serif);font-weight:400;letter-spacing:-0.022em;line-height:0.98;color:var(--ink);}
  .accent-ital{font-style:italic;color:var(--accent);font-family:var(--serif);}
  .lede{font-family:var(--serif);font-size:21px;line-height:1.45;color:var(--ink-2);letter-spacing:-0.005em;}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-3);}
  .meta-text{font-family:var(--mono);font-size:12.5px;letter-spacing:0.04em;color:var(--ink-3);}
  .btn{display:inline-flex;align-items:center;gap:10px;padding:13px 20px;border-radius:999px;font-size:14.5px;font-weight:500;border:1px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;text-decoration:none;font-family:var(--sans);}
  .btn-primary{background:var(--ink);color:var(--paper);}
  .btn-primary:hover{background:#000;}
  .btn-ghost{background:transparent;color:var(--ink);border-color:var(--ink);}
  .btn-ghost:hover{background:var(--ink);color:var(--paper);}
  .arr{display:inline-block;transition:transform .2s;}
  .btn:hover .arr{transform:translateX(3px);}
  .page-header{padding:64px 0 56px;}
  .header-meta{display:flex;align-items:baseline;gap:18px;margin-bottom:28px;flex-wrap:wrap;}
  .page-h1{font-size:clamp(42px,5.5vw,84px);letter-spacing:-0.022em;line-height:0.98;max-width:16ch;}
  .page-lede{margin-top:24px;max-width:58ch;}
  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;}
  .col-h2{font-size:clamp(36px,4vw,56px);letter-spacing:-0.022em;line-height:1;margin:14px 0 20px;}
  .body-copy{font-size:15.5px;color:var(--ink-2);line-height:1.7;}
  .feature-list{list-style:none;padding:0;margin:20px 0;display:grid;gap:12px;}
  .feature-list li{font-size:14.5px;color:var(--ink-2);line-height:1.5;padding-left:20px;position:relative;}
  .feature-list li::before{content:'✓';position:absolute;left:0;color:var(--accent);font-weight:600;}
  .ai-callout{font-size:13.5px;color:var(--accent);background:color-mix(in oklab,var(--accent) 8%,var(--paper));border:1px solid color-mix(in oklab,var(--accent) 20%,var(--paper));border-radius:6px;padding:12px 16px;margin-top:20px;line-height:1.6;}
  .problems-card{background:var(--paper-2);border:1px solid var(--rule);padding:28px;display:flex;flex-direction:column;gap:24px;}
  .problem{display:flex;gap:12px;align-items:flex-start;}
  .problem-x{color:#B84040;font-size:16px;flex-shrink:0;margin-top:2px;}
  .problem-title{font-family:var(--serif);font-size:17px;letter-spacing:-0.01em;color:var(--ink);margin-bottom:4px;}
  .problem-desc{font-size:13px;color:var(--ink-3);line-height:1.6;}
  .sec-head{margin-bottom:56px;}
  .sec-h2{font-size:clamp(38px,4.6vw,64px);letter-spacing:-0.02em;line-height:1.02;margin-top:14px;}
  .process{display:flex;flex-direction:column;}
  .process-step{display:flex;gap:32px;padding:28px 0;border-bottom:1px solid var(--rule);align-items:flex-start;}
  .process-step:first-child{border-top:1px solid var(--rule);}
  .step-n{font-family:var(--serif);font-size:2rem;font-weight:400;color:var(--accent);opacity:0.35;flex-shrink:0;min-width:48px;line-height:1;}
  .step-h{font-family:var(--serif);font-size:20px;letter-spacing:-0.01em;color:var(--ink);margin-bottom:6px;}
  .step-p{font-size:14.5px;color:var(--ink-2);line-height:1.65;}
  .pricing-block{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;background:var(--paper-2);border:1px solid var(--rule);padding:56px;}
  .pricing-h2{font-size:clamp(38px,4.6vw,60px);letter-spacing:-0.022em;line-height:1;margin-top:14px;}
  .pricing-ledger{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);}
  .pricing-ledger>div{padding:24px 20px;border-right:1px solid var(--rule);}
  .pricing-ledger>div:last-child{border-right:none;}
  .k{font-family:var(--mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-3);margin-bottom:10px;}
  .v{font-family:var(--serif);font-size:28px;letter-spacing:-0.02em;line-height:1;color:var(--ink);}
  .v-sub{font-size:16px;color:var(--ink-3);}
  .sub{font-size:12px;color:var(--ink-3);margin-top:6px;}
  .faq{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--rule);}
  .faq details{padding:24px 0;border-bottom:1px solid var(--rule);}
  .faq details:nth-child(even){padding-left:32px;border-left:1px solid var(--rule);}
  .faq details:nth-child(odd){padding-right:32px;}
  .faq summary{list-style:none;cursor:pointer;font-family:var(--serif);font-size:19px;letter-spacing:-0.01em;color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:16px;}
  .faq summary::-webkit-details-marker{display:none;}
  .faq summary::after{content:'+';font-family:var(--sans);font-size:22px;color:var(--ink-3);font-weight:300;transition:transform .2s;flex-shrink:0;}
  .faq details[open] summary::after{transform:rotate(45deg);}
  .faq details p{margin:14px 0 0;color:var(--ink-2);font-size:15px;line-height:1.65;max-width:52ch;}
  .cta-wrap{padding:40px 0;}
  .cta-h2{font-size:clamp(48px,6vw,88px);max-width:14ch;margin:18px 0 24px;color:var(--paper);}
  @media(max-width:1000px){
    .two-col,.pricing-block{grid-template-columns:1fr;gap:40px;}
    .pricing-ledger{grid-template-columns:1fr;}
    .pricing-ledger>div{border-right:none;border-bottom:1px solid var(--rule);}
    .pricing-ledger>div:last-child{border-bottom:none;}
    .faq{grid-template-columns:1fr;}
    .faq details:nth-child(even){padding-left:0;border-left:none;}
    .faq details:nth-child(odd){padding-right:0;}
  }
  @media(max-width:640px){.wrap{padding:0 20px;}.section{padding:64px 0;}}
</style>
