---
import Base from '../../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "RevOps and Fractional CRO Services",
  "provider": { "@type": "Organization", "name": "OrangeCore Group" },
  "areaServed": ["Plano TX", "Dallas TX", "DFW", "United States"],
  "description": "Productized RevOps and fractional CRO services for B2B SaaS and fintech. Fixed-fee engagements with defined deliverables."
};
---

<Base
  title="RevOps & Fractional CRO Services | Fixed-Fee Engagements | OrangeCore Group"
  description="Productized RevOps and fractional CRO services for B2B SaaS and fintech. Foundation audit from $5,500. Full HubSpot buildout from $14,500. No hourly billing."
  schema={schema}
>

  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="wrap">
      <div class="header-meta">
        <span class="eyebrow">Services & Pricing</span>
        <span class="meta-text">— A scope, a number, a date.</span>
      </div>
      <h1 class="display page-h1">
        Three engagements.<br>
        <em class="accent-ital">Three prices.</em><br>
        Zero surprises.
      </h1>
      <p class="lede page-lede">
        Each one is productized — fixed scope, fixed deliverables, fixed end date.
        Open any tier below to see exactly what's included, week by week,
        and what shows up in your inbox when we're done.
      </p>
    </div>
  </header>

  <hr class="rule" />

  <!-- TIER OVERVIEW — 3 column + enterprise row -->
  <section class="section">
    <div class="wrap">
      <div class="tiers">
        <article class="tier">
          <div class="tier-head">
            <span class="tier-num">Tier 01</span>
            <span class="tier-stamp">Diagnostic</span>
          </div>
          <h3 class="tier-name display">Foundation</h3>
          <p class="tier-pitch">Something feels off but nobody can agree on what. We tell you exactly what's broken and what to fix first.</p>
          <div class="tier-price">
            <span class="amt">$5,500</span>
            <span class="terms">One-time · 10 business days</span>
          </div>
          <ul class="tier-bullets">
            <li>Full revenue ops audit — pipeline, CRM, ICP, handoff</li>
            <li>Gap analysis with prioritized fix list</li>
            <li>90-day RevOps roadmap, ready to execute</li>
            <li>CRM health scorecard + 60-min readout</li>
          </ul>
          <a href="#foundation" class="btn btn-ghost tier-cta">See full scope <span class="arr">→</span></a>
        </article>

        <article class="tier tier-featured">
          <div class="tier-head">
            <span class="tier-num">Tier 02</span>
            <span class="tier-stamp tier-stamp-hot">Most chosen</span>
          </div>
          <h3 class="tier-name display">Operate</h3>
          <p class="tier-pitch">A fractional CRO in the room every month — defined deliverables, not a standing check-in you dread scheduling.</p>
          <div class="tier-price">
            <span class="amt">$7,500<span class="per">/mo</span></span>
            <span class="terms">3-month minimum</span>
          </div>
          <ul class="tier-bullets">
            <li>Monthly pipeline review + forecast with leadership</li>
            <li>One major deliverable per month, defined at kickoff</li>
            <li>Ongoing CRM management and data hygiene</li>
            <li>Bi-weekly team coaching + async Slack access</li>
          </ul>
          <a href="#operate" class="btn btn-primary tier-cta">See full scope <span class="arr">→</span></a>
        </article>

        <article class="tier">
          <div class="tier-head">
            <span class="tier-num">Tier 03</span>
            <span class="tier-stamp">Project</span>
          </div>
          <h3 class="tier-name display">Build</h3>
          <p class="tier-pitch">The full engagement. We go in, build it right, hand it off clean. No loose ends, no "let's revisit next quarter."</p>
          <div class="tier-price">
            <span class="amt">$14,500</span>
            <span class="terms">One-time · 3–4 weeks</span>
          </div>
          <ul class="tier-bullets">
            <li>Full CRM buildout or cleanup (HubSpot, Salesforce)</li>
            <li>Pipeline stages, ICP definition, lead scoring</li>
            <li>Sales playbook + reporting dashboards</li>
            <li>30-day Slack support post-delivery</li>
          </ul>
          <a href="#build" class="btn btn-ghost tier-cta">See full scope <span class="arr">→</span></a>
        </article>
      </div>

      <!-- Enterprise row -->
      <div class="enterprise-row">
        <div class="enterprise-left">
          <span class="eyebrow">Custom Enterprise</span>
          <h3 class="display enterprise-name">Complex environment? Let's scope it together.</h3>
          <p class="enterprise-desc">Multi-location orgs, legacy CRM migrations, enterprise procurement environments, or fintech/payments companies with compliance-adjacent sales cycles. If it doesn't fit neatly into one of the tiers above, this is the conversation to have.</p>
          <div class="enterprise-checks">
            <span><em class="accent-ital">✓</em> Custom scope defined upfront</span>
            <span><em class="accent-ital">✓</em> Flat-fee or milestone billing</span>
            <span><em class="accent-ital">✓</em> Payments & fintech experience available</span>
            <span><em class="accent-ital">✓</em> SDVOSB certified — qualifies for set-aside contracts</span>
          </div>
        </div>
        <div class="enterprise-right">
          <p class="display" style="font-size:28px;letter-spacing:-0.02em;">Starts at $25K</p>
          <p class="meta-text" style="margin:4px 0 20px;">Scoped per engagement</p>
          <a href="/contact/" class="btn btn-ghost">Let's talk scope <span class="arr">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- DETAILED TIER BREAKDOWNS -->
  <section class="section">
    <div class="wrap">

      <!-- FOUNDATION -->
      <article class="svc" id="foundation">
        <div class="svc-head">
          <div class="svc-meta">
            <span class="svc-num">Tier 01</span>
            <span class="meta-text">Diagnostic · One-time engagement</span>
          </div>
          <h2 class="display svc-name">Foundation</h2>
          <p class="lede svc-pitch">Something feels off but nobody can agree on what. Ten business days later, you'll have a written, prioritized, board-defensible answer.</p>
          <div class="svc-stats">
            <div><span class="k">Investment</span><span class="v">$5,500</span></div>
            <div><span class="k">Duration</span><span class="v">10 business days</span></div>
            <div><span class="k">Format</span><span class="v">One-time, flat fee</span></div>
            <div><span class="k">Deliverable</span><span class="v">Written report & readout</span></div>
          </div>
          <div class="svc-cta">
            <a href="/contact/" class="btn btn-primary">Book Foundation <span class="arr">→</span></a>
            <button class="btn btn-quiet drawer-toggle" data-target="drawer-foundation" aria-expanded="true">
              Hide what's included
            </button>
          </div>
        </div>
        <div class="drawer is-open" id="drawer-foundation">
          <div class="drawer-grid">
            <div class="drawer-col">
              <h4 class="drawer-h">Week 1 — Listen</h4>
              <ul class="drawer-list">
                <li>Structured intake with founder, sales lead, marketing lead, RevOps</li>
                <li>Read-only access to CRM, BI, ad accounts, helpdesk</li>
                <li>30-day pipeline & conversion deep-dive</li>
                <li>Stakeholder interviews (5–7 people)</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Week 2 — Diagnose</h4>
              <ul class="drawer-list">
                <li>Funnel analysis — stage-by-stage drop-off</li>
                <li>CRM data quality audit</li>
                <li>Lead scoring & lifecycle review</li>
                <li>Tech stack & cost-of-ownership assessment</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Day 10 — Hand-off</h4>
              <ul class="drawer-list">
                <li>Written diagnostic report (12–18 pages)</li>
                <li>Prioritized 90-day fix list with effort estimates</li>
                <li>Live executive readout (90 minutes)</li>
                <li>Recording & appendix for absent stakeholders</li>
              </ul>
            </div>
          </div>
          <div class="drawer-foot">
            <span class="meta-text">Best fit for —</span>
            <span>Companies with a "we know something is wrong, we just can't agree on what" problem. Pre-board-meeting clarity in two weeks.</span>
          </div>
        </div>
      </article>

      <hr class="rule" style="margin:64px 0;" />

      <!-- OPERATE -->
      <article class="svc svc-featured" id="operate">
        <div class="svc-head">
          <div class="svc-meta">
            <span class="svc-num">Tier 02</span>
            <span class="meta-text">Ongoing · Most chosen</span>
            <span class="tag tag-hot"><span class="dot"></span>Featured</span>
          </div>
          <h2 class="display svc-name">Operate</h2>
          <p class="lede svc-pitch">A fractional CRO in the room every month. Defined deliverables, board-ready output, and hands actually in the system — not a standing check-in you dread scheduling.</p>
          <div class="svc-stats">
            <div><span class="k">Investment</span><span class="v">$7,500<span class="v-mo">/mo</span></span></div>
            <div><span class="k">Duration</span><span class="v">3-month minimum</span></div>
            <div><span class="k">Format</span><span class="v">Monthly, cancellable thereafter</span></div>
            <div><span class="k">Deliverable</span><span class="v">Operating cadence + artifacts</span></div>
          </div>
          <div class="svc-cta">
            <a href="/contact/" class="btn btn-featured">Book Operate <span class="arr">→</span></a>
            <button class="btn btn-quiet-featured drawer-toggle" data-target="drawer-operate" aria-expanded="true">
              Hide what's included
            </button>
          </div>
        </div>
        <div class="drawer is-open" id="drawer-operate">
          <div class="drawer-grid">
            <div class="drawer-col">
              <h4 class="drawer-h">Weekly</h4>
              <ul class="drawer-list">
                <li>2-hour working session with revenue leadership</li>
                <li>Pipeline review & forecast hygiene</li>
                <li>Deal coaching on top opportunities</li>
                <li>Async updates between sessions</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Monthly</h4>
              <ul class="drawer-list">
                <li>Board-ready revenue narrative (PDF)</li>
                <li>Cohort & retention readout</li>
                <li>Sales/marketing alignment session</li>
                <li>Tech stack & spend review</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Hands-on, ongoing</h4>
              <ul class="drawer-list">
                <li>HubSpot/CRM execution — not just advice</li>
                <li>Sales team coaching & deal reviews</li>
                <li>Comp plan & territory adjustments</li>
                <li>Hiring scorecards for revenue roles</li>
              </ul>
            </div>
          </div>
          <div class="drawer-foot drawer-foot-featured">
            <span class="meta-text">Best fit for —</span>
            <span>$3M–$30M ARR companies in transition: between a head of sales, post-Series-A, or pre-CRO hire. We hold the line until the right full-time leader is in seat.</span>
          </div>
        </div>
      </article>

      <hr class="rule" style="margin:64px 0;" />

      <!-- BUILD -->
      <article class="svc" id="build">
        <div class="svc-head">
          <div class="svc-meta">
            <span class="svc-num">Tier 03</span>
            <span class="meta-text">Project · One-time engagement</span>
          </div>
          <h2 class="display svc-name">Build</h2>
          <p class="lede svc-pitch">The full engagement. We come in, build it right, hand it off clean. Three to four weeks. No loose ends. No "let's revisit next quarter."</p>
          <div class="svc-stats">
            <div><span class="k">Investment</span><span class="v">$14,500</span></div>
            <div><span class="k">Duration</span><span class="v">3–4 weeks</span></div>
            <div><span class="k">Format</span><span class="v">One-time, flat fee</span></div>
            <div><span class="k">Deliverable</span><span class="v">Working systems, documented</span></div>
          </div>
          <div class="svc-cta">
            <a href="/contact/" class="btn btn-primary">Book Build <span class="arr">→</span></a>
            <button class="btn btn-quiet drawer-toggle" data-target="drawer-build" aria-expanded="true">
              Hide what's included
            </button>
          </div>
        </div>
        <div class="drawer is-open" id="drawer-build">
          <div class="drawer-grid">
            <div class="drawer-col">
              <h4 class="drawer-h">Week 1 — Architecture</h4>
              <ul class="drawer-list">
                <li>Lifecycle & lead-stage definitions</li>
                <li>Object schema (deal, company, contact)</li>
                <li>Lead scoring model — fit + intent</li>
                <li>Routing & SLA logic</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Weeks 2–3 — Build</h4>
              <ul class="drawer-list">
                <li>HubSpot rebuild or migration (full-stack)</li>
                <li>Attribution & reporting wired in</li>
                <li>Workflow automation, end-to-end</li>
                <li>Dashboards: exec, sales, marketing, ops</li>
              </ul>
            </div>
            <div class="drawer-col">
              <h4 class="drawer-h">Week 4 — Hand-off</h4>
              <ul class="drawer-list">
                <li>Sales playbook (PDF + Notion mirror)</li>
                <li>Admin runbook & data dictionary</li>
                <li>Live training with sales & marketing teams</li>
                <li>30-day post-launch support included</li>
              </ul>
            </div>
          </div>
          <div class="drawer-foot">
            <span class="meta-text">Best fit for —</span>
            <span>Companies with a CRM that's a graveyard, an attribution model nobody trusts, or a HubSpot instance someone built three admins ago. Reset and own it.</span>
          </div>
        </div>
      </article>

    </div>
  </section>

  <hr class="rule" />

  <!-- ADD-ONS -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <span class="eyebrow">Add-ons</span>
        <h2 class="display sec-h2">Need something <em class="accent-ital">specific?</em></h2>
        <p class="lede" style="margin-top:14px;max-width:52ch;font-size:18px;">These can be added to any tier or purchased standalone.</p>
      </div>
      <div class="addons-grid">
        <div class="addon"><p class="addon-name">HubSpot Migration</p><p class="addon-desc">Full migration from another CRM or legacy HubSpot setup. Clean data import, custom properties, workflows rebuilt.</p><p class="addon-price">$4,500</p></div>
        <div class="addon"><p class="addon-name">GTM Strategy Sprint</p><p class="addon-desc">2-week focused engagement — ICP, positioning, channel prioritization, outbound strategy.</p><p class="addon-price">$5,500</p></div>
        <div class="addon"><p class="addon-name">Board / Investor Prep</p><p class="addon-desc">Pipeline narrative, revenue forecast model, and GTM slide package for your next board meeting or fundraise.</p><p class="addon-price">$2,000</p></div>
        <div class="addon"><p class="addon-name">Comp Plan Design</p><p class="addon-desc">Sales compensation structure for AEs, SDRs, and CS. Quota modeling, accelerators, and spiff design included.</p><p class="addon-price">$3,000</p></div>
        <div class="addon"><p class="addon-name">RevOps Tech Stack Audit</p><p class="addon-desc">Full review of your current tool stack — what to keep, cut, or add. Includes vendor comparison where relevant.</p><p class="addon-price">$2,500</p></div>
        <div class="addon"><p class="addon-name">Payments / Fintech Vertical Pack</p><p class="addon-desc">Playbook and ICP framework built specifically for payments, BNPL, or fintech — MCC, interchange, and enterprise procurement context baked in.</p><p class="addon-price">$3,500</p></div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- FAQ -->
  <section class="section section-band">
    <div class="wrap">
      <div class="sec-head" style="margin-bottom:48px;">
        <span class="eyebrow">Boundary conditions</span>
        <h2 class="display sec-h2">
          Questions you should be<br>
          <em class="accent-ital">asking out loud.</em>
        </h2>
      </div>
      <div class="faq">
        <details>
          <summary>Why no hourly billing?</summary>
          <p>Because hourly billing rewards slowness. The longer it takes, the more we make. That's a misaligned incentive, and it's why most consulting engagements quietly inflate. Flat fee means we're paid to ship — not to bill.</p>
        </details>
        <details>
          <summary>What does "AI-augmented" actually mean?</summary>
          <p>Roughly 60% of the analytical and documentation work — funnel analysis, data hygiene flagging, playbook drafting, dashboard scaffolding — is accelerated by tooling we've built internally. You get senior operator judgment at project speed. We don't charge less for it; we just deliver faster.</p>
        </details>
        <details>
          <summary>Do you sign NDAs?</summary>
          <p>Yes. Mutual NDA signed before kickoff, without exception.</p>
        </details>
        <details>
          <summary>What if Operate isn't working after month one?</summary>
          <p>Three-month minimum is real, but if month one feels wrong on either side we'll have an honest conversation in week three and decide together. We don't want to take money for an engagement that isn't earning its keep.</p>
        </details>
        <details>
          <summary>Can you replace a full-time CRO?</summary>
          <p>For a season — yes. Permanently — no, and you shouldn't want that. Operate is designed to hold the line and build the function so a full-time hire walks into something running, not something on fire.</p>
        </details>
        <details>
          <summary>What stack do you work in?</summary>
          <p>HubSpot is home base. Salesforce when required. Outreach, Apollo, Clay on the outbound side. Looker, Mode, and Hex on the data side. Plano-based, working remote with on-sites when useful.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="section section-dark">
    <div class="wrap cta-wrap">
      <span class="eyebrow">Based in Plano, TX · Serving clients nationwide</span>
      <h2 class="display cta-h2">
        Pick a scope.<br>
        <em class="accent-ital">Or let me pick one.</em>
      </h2>
      <p class="lede" style="color:#C9C0B2;max-width:56ch;">
        If you're not sure which tier fits, that's a 30-minute conversation, not a sales call.
        I'll tell you which one — or that none of them — is right.
      </p>
      <div style="display:flex;gap:14px;margin-top:32px;flex-wrap:wrap;">
        <a href="/contact/" class="btn" style="background:var(--paper);color:var(--ink);">Book a discovery call <span class="arr">→</span></a>
        <a href="/#diagnostic" class="btn" style="color:var(--paper);border:1px solid #4D453C;">Take the diagnostic instead</a>
      </div>
    </div>
  </section>

</Base>

<script>
  document.querySelectorAll('.drawer-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.getElementById((btn as HTMLElement).dataset.target!);
      const open = target?.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(open));
      btn.textContent = open ? 'Hide what\u2019s included' : 'See what\u2019s included';
    });
  });
</script>

<style>
  :root {
    --paper:      #F4EFE7;
    --paper-2:    #EBE4D7;
    --paper-3:    #E2D9C8;
    --ink:        #1A1714;
    --ink-2:      #3A332C;
    --ink-3:      #6B6258;
    --rule:       #C9BFAD;
    --rule-soft:  #D9D0BE;
    --accent:     #C2511A;
    --serif:      'Source Serif 4', Georgia, serif;
    --sans:       'Inter Tight', 'Helvetica Neue', Arial, sans-serif;
    --mono:       'JetBrains Mono', monospace;
  }
  :global(body) { background:var(--paper) !important; color:var(--ink) !important; font-family:var(--sans) !important; }

  .wrap { max-width:1240px; margin:0 auto; padding:0 32px; }
  .rule { height:1px; background:var(--rule); border:0; margin:0; }
  .section { padding:96px 0; }
  .section-band { background:var(--paper-2); border-top:1px solid var(--rule); border-bottom:1px solid var(--rule); }
  .section-dark { background:var(--ink); color:var(--paper); }
  .section-dark .eyebrow { color:#B7AC9C; }

  .display { font-family:var(--serif); font-weight:400; letter-spacing:-0.022em; line-height:0.98; color:var(--ink); }
  .accent-ital { font-style:italic; color:var(--accent); font-family:var(--serif); }
  .lede { font-family:var(--serif); font-size:21px; line-height:1.45; color:var(--ink-2); letter-spacing:-0.005em; }
  .eyebrow { font-family:var(--mono); font-size:12px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-3); }
  .meta-text { font-family:var(--mono); font-size:12.5px; letter-spacing:0.04em; color:var(--ink-3); }

  .btn { display:inline-flex; align-items:center; gap:10px; padding:13px 20px; border-radius:999px; font-size:14.5px; font-weight:500; border:1px solid transparent; cursor:pointer; transition:all .15s ease; white-space:nowrap; text-decoration:none; font-family:var(--sans); }
  .btn-primary { background:var(--ink); color:var(--paper); }
  .btn-primary:hover { background:#000; }
  .btn-ghost { background:transparent; color:var(--ink); border-color:var(--ink); }
  .btn-ghost:hover { background:var(--ink); color:var(--paper); }
  .btn-quiet { color:var(--ink-2); padding:8px 0; border-radius:0; border-bottom:1px solid var(--ink-2); background:none; font-size:14px; }
  .btn-featured { background:var(--paper); color:var(--ink); border-color:var(--paper); border-radius:999px; }
  .btn-featured:hover { background:#fff; }
  .btn-quiet-featured { color:var(--paper); padding:8px 0; border-radius:0; border-bottom:1px solid rgba(255,255,255,0.3); background:none; font-size:14px; opacity:0.8; }
  .arr { display:inline-block; transition:transform .2s; }
  .btn:hover .arr { transform:translateX(3px); }

  .tag { display:inline-flex; align-items:center; gap:8px; padding:5px 12px; border:1px solid var(--rule); border-radius:999px; font-family:var(--mono); font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-2); }
  .dot { width:6px; height:6px; border-radius:50%; background:var(--accent); flex-shrink:0; }
  .tag-hot { color:var(--paper); background:var(--accent); border-color:var(--accent); }
  .tag-hot .dot { background:var(--paper); }

  /* page header */
  .page-header { padding:64px 0 56px; }
  .header-meta { display:flex; align-items:baseline; gap:18px; margin-bottom:28px; flex-wrap:wrap; }
  .page-h1 { font-size:clamp(48px,6.4vw,96px); letter-spacing:-0.022em; line-height:0.98; max-width:14ch; }
  .page-lede { margin-top:32px; max-width:60ch; }

  /* tier overview */
  .tiers { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--rule); border:1px solid var(--rule); margin-bottom:2px; }
  .tier { background:var(--paper-2); padding:36px 32px; display:flex; flex-direction:column; }
  .tier-featured { background:var(--paper); }
  .tier-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
  .tier-num { font-family:var(--mono); font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-3); }
  .tier-stamp { font-family:var(--mono); font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-3); border:1px solid var(--rule); padding:3px 8px; border-radius:3px; }
  .tier-stamp-hot { background:var(--accent); color:#fff; border-color:var(--accent); }
