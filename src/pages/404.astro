---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found | OrangeCore Group"
  description="The page you're looking for doesn't exist. Head back to OrangeCore Group's homepage."
>
  <section class="not-found">
    <div class="container">
      <p class="not-found-num">404</p>
      <h1>That page doesn't exist.</h1>
      <p class="not-found-sub">Either the URL is wrong or the page moved. Either way, you can start over from here.</p>
      <div class="not-found-links">
        <a href="/" class="btn-primary">Back to homepage</a>
        <a href="/services/" class="btn-outline">See services & pricing</a>
        <a href="/contact/" class="btn-outline">Book a discovery call</a>
      </div>
    </div>
  </section>
</Base>

<style>
.not-found {
  text-align: center;
  padding: 8rem 0;
}
.not-found-num {
  font-family: var(--font-serif);
  font-size: 7rem;
  font-weight: 700;
  color: var(--orange);
  opacity: 0.2;
  line-height: 1;
  margin-bottom: 1rem;
}
.not-found h1 {
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  color: var(--charcoal);
  margin-bottom: 1rem;
}
.not-found-sub {
  font-size: 16px;
  color: var(--mid-gray);
  max-width: 400px;
  margin: 0 auto 2.5rem;
  line-height: 1.7;
}
.not-found-links {
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}
</style>
