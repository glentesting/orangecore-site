---
import Base from '../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "OrangeCore Group",
  "url": "https://orangecoregroup.com",
  "description": "Fractional CRO and RevOps consulting for B2B SaaS and fintech companies.",
  "founder": { "@type": "Person", "name": "Glen Swindell" },
  "address": { "@type": "PostalAddress", "addressLocality": "Plano", "addressRegion": "TX", "addressCountry": "US" },
  "areaServed": ["Plano TX", "Dallas TX", "DFW", "United States"]
};
---

<Base
  title="Fractional CRO & RevOps Consulting | OrangeCore Group | Plano, TX"
  description="OrangeCore Group delivers fractional CRO and RevOps consulting for B2B SaaS and fintech companies. Fixed-fee engagements. Real deliverables. Based in Plano, TX."
  schema={schema}
>

  <!-- HERO — cream bg, heavy typography -->
  <header class="hero">
    <div class="wrap">
      <div class="hero-top">
        <span class="availability">
          <span class="avail-dot"></span>
          Booking · Q3 2026
        </span>
        <span class="hero-location">Plano, TX · Serving clients nationwide</span>
      </div>

      <div class="hero-grid">
        <div class="hero-left">
          <h1 class="hero-h1">
            A fractional CRO<br>
            <em class="orange-ital">who actually ships</em><br>
            — fixed price,<br>fixed end date.
          </h1>
          <p class="hero-sub">
            OrangeCore is a one-person revenue practice for B2B SaaS and fintech operators
            tired of consultants billing by the hour and leaving with the playbook.
            Fixed scope. Fixed price. Yours to keep when we're done.
          </p>
          <div class="hero-actions">
            <a href="#diagnostic" class="btn-orange">Take the 90-second diagnostic <span class="arr">→</span></a>
            <a href="/services/" class="btn-outline-dark">See pricing & scope</a>
          </div>
        </div>

        <aside class="hero-right">
          <div class="portrait-wrap">
            <div class="ph portrait-ph" role="img" aria-label="Glen Swindell, fractional CRO and RevOps consultant, Plano TX">
              Glen — portrait<br><span style="font-size:10px;opacity:0.6;">(replace src)</span>
            </div>
            <div class="portrait-cap">
              <span class="portrait-name">Glen <em class="orange-ital">— Founder, Fractional CRO</em></span>
              <span class="portrait-meta">U.S. Army Veteran · 10+ yrs revenue leadership · B2B SaaS & Fintech</span>
            </div>
          </div>
        </aside>
      </div>

      <!-- STAT BAR -->
      <div class="stat-bar">
        <div class="stat-item">
          <span class="stat-num">14<span class="stat-unit">days</span></span>
          <span class="stat-label">Average delivery, end to end</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat-item">
          <span class="stat-num">$0<span class="stat-unit">/hr</span></span>
          <span class="stat-label">No hourly. No retainers. No surprises.</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat-item">
          <span class="stat-num">$67M<span class="stat-unit">+</span></span>
          <span class="stat-label">ARR secured across SaaS, fintech & payments</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat-item">
          <span class="stat-num">22<span class="stat-unit">%</span></span>
          <span class="stat-label">Avg ARR lift across 10+ engagements</span>
        </div>
      </div>
    </div>
  </header>

  <!-- PROOF STRIP -->
  <div class="proof-strip">
    <div class="wrap proof-row">
      <span class="proof-label">Past engagements</span>
      <div class="proof-items">
        <span>Enterprise Fintech</span>
        <span class="proof-sep">·</span>
        <span>Global Payments</span>
        <span class="proof-sep">·</span>
        <span>B2B SaaS</span>
        <span class="proof-sep">·</span>
        <span>Government Finance</span>
        <span class="proof-sep">·</span>
        <span>eCommerce</span>
      </div>
    </div>
  </div>

  <!-- MANIFESTO — cream with orange left border -->
  <section class="section manifesto-section">
    <div class="wrap">
      <div class="manifesto-inner">
        <div class="manifesto-head">
          <span class="mono-label">01 — The thesis</span>
          <h2 class="section-h2">
            Most fractional CROs<br>sell <em class="orange-ital">strategy.</em><br>
            We sell <em class="orange-ital">finished work.</em>
          </h2>
        </div>
        <div class="contrast">
          <div class="contrast-col contrast-old">
            <p class="contrast-label">Traditional fractional CRO / RevOps</p>
            <ul class="contrast-list">
              <li>Hourly billing — budget creep is the business model.</li>
              <li>Weeks of "discovery" before anything actually gets built.</li>
              <li>Vague deliverables. "Strategic guidance." Hard to measure.</li>
              <li>When they leave, the knowledge leaves with them.</li>
              <li>Scope quietly expands. The engagement never really ends.</li>
            </ul>
          </div>
          <div class="contrast-col contrast-new">
            <p class="contrast-label contrast-label-new">OrangeCore productized service</p>
            <ul class="contrast-list">
              <li>Flat fee. You see the number before you sign anything.</li>
              <li>Structured intake day one. Building starts week one.</li>
              <li>Specific deliverables, documented and handed off — yours.</li>
              <li>Everything lives in your systems when we're done. Not ours.</li>
              <li>Defined end date. Retainer is optional, never required.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING — dark background -->
  <section class="section section-dark" id="pricing">
    <div class="wrap">
      <div class="section-head-centered">
        <span class="mono-label" style="color:#8A8073;">02 — Three ways to work together</span>
        <h2 class="section-h2 light">
          Pick a scope.<br>
          <em class="orange-ital">Know the price.</em> Know the date.
        </h2>
        <p class="section-sub light-sub">Every engagement has a defined scope and a defined end. You'll know exactly what you're getting before anything gets signed.</p>
      </div>

      <div class="tiers">
        <article class="tier">
          <div class="tier-head-row">
            <span class="tier-num">Tier 01</span>
            <span class="tier-tag">Diagnostic</span>
          </div>
          <h3 class="tier-name">Foundation</h3>
          <p class="tier-pitch">Something feels off but nobody can agree on what. We tell you exactly what's broken and what to fix first.</p>
          <div class="tier-price-row">
            <span class="tier-price">$5,500</span>
            <span class="tier-terms">One-time · 10 days</span>
          </div>
          <ul class="tier-list">
            <li>Full revenue ops audit — pipeline, CRM, ICP, handoff</li>
            <li>Gap analysis with prioritized fix list</li>
            <li>90-day RevOps roadmap, ready to execute</li>
            <li>CRM health scorecard + 60-min readout</li>
          </ul>
          <a href="/services/#foundation" class="tier-btn tier-btn-ghost">See what's included →</a>
        </article>

        <article class="tier tier-hot">
          <div class="tier-head-row">
            <span class="tier-num">Tier 02</span>
            <span class="tier-tag tier-tag-hot">Most chosen</span>
          </div>
          <h3 class="tier-name">Operate</h3>
          <p class="tier-pitch">A fractional CRO in the room every month — defined deliverables, not a standing check-in you dread scheduling.</p>
          <div class="tier-price-row">
            <span class="tier-price">$7,500<span class="tier-per">/mo</span></span>
            <span class="tier-terms">3-month minimum</span>
          </div>
          <ul class="tier-list">
            <li>Monthly pipeline review + forecast with leadership</li>
            <li>One major deliverable per month, defined at kickoff</li>
            <li>Ongoing CRM management and data hygiene</li>
            <li>Bi-weekly team coaching + async Slack access</li>
          </ul>
          <a href="/services/#operate" class="tier-btn tier-btn-orange">See what's included →</a>
        </article>

        <article class="tier">
          <div class="tier-head-row">
            <span class="tier-num">Tier 03</span>
            <span class="tier-tag">Project</span>
          </div>
          <h3 class="tier-name">Build</h3>
          <p class="tier-pitch">The full engagement. We go in, build it right, hand it off clean. No loose ends, no "let's revisit next quarter."</p>
          <div class="tier-price-row">
            <span class="tier-price">$14,500</span>
            <span class="tier-terms">One-time · 3–4 weeks</span>
          </div>
          <ul class="tier-list">
            <li>Full CRM buildout or cleanup (HubSpot, Salesforce)</li>
            <li>Pipeline stages, ICP definition, lead scoring</li>
            <li>Sales playbook + reporting dashboards</li>
            <li>30-day Slack support post-delivery</li>
          </ul>
          <a href="/services/#build" class="tier-btn tier-btn-ghost">See what's included →</a>
        </article>
      </div>

      <p class="tiers-footnote">
        All engagements are AI-augmented — faster delivery, more consistent output. Not a gimmick; it's how we move at project speed on a consultant budget.
      </p>
    </div>
  </section>

  <!-- DIAGNOSTIC — slightly lighter dark -->
  <section class="section section-mid" id="diagnostic">
    <div class="wrap diag-wrap">
      <div class="diag-left">
        <span class="mono-label" style="color:#8A8073;">03 — Live diagnostic</span>
        <h2 class="section-h2 light">
          Four questions.<br>
          <em class="orange-ital">Ninety seconds.</em><br>
          A real read on your<br>revenue function.
        </h2>
        <p class="diag-sub">No email gate. No download. An honest signal of where you sit — and which tier (if any) is the right fit.</p>
        <div class="diag-progress-wrap">
          <div class="diag-bar-track"><span id="diag-fill" style="width:0%"></span></div>
          <span class="mono-label" id="diag-step-label" style="color:#8A8073;margin-top:8px;display:block;">Question 1 of 4</span>
        </div>
      </div>
      <div class="diag-right">
        <div class="diag-card">
          <div id="diag-questions"></div>
          <div id="diag-result" hidden></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FIT — cream, breathe -->
  <section class="section fit-section">
    <div class="wrap">
      <div class="fit-head">
        <span class="mono-label">04 — Who this is for</span>
        <h2 class="section-h2">
          Worth a conversation if<br>
          <em class="orange-ital">any of these sound familiar.</em>
        </h2>
      </div>
      <div class="fit-grid">
        <div class="fit-yes">
          <p class="fit-col-label">Probably a fit</p>
          <ul class="fit-list">
            <li>Revenue is inconsistent — good months, bad months, no real explanation.</li>
            <li>Your CRM is a graveyard. The team knows it's wrong so they stopped using it.</li>
            <li>Sales and marketing can't agree on what a qualified lead looks like.</li>
            <li>Board meeting incoming and the pipeline story isn't airtight.</li>
            <li>You need CRO-level thinking but $250K in salary isn't in the budget.</li>
            <li>You're in fintech, payments, or B2B SaaS — and tired of generalists who don't know the space.</li>
          </ul>
        </div>
        <div class="fit-no">
          <p class="fit-col-label fit-col-label-no">Probably not</p>
          <ul class="fit-list fit-list-no">
            <li>Pre-revenue, still figuring out if anyone wants what you're selling.</li>
            <li>You need a day-to-day sales manager. That's a hire, not a consultant.</li>
            <li>You want someone in meetings giving general advice with no defined output.</li>
            <li>You're not comfortable letting someone see the real numbers.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- GLEN — dark -->
  <section class="section section-dark">
    <div class="wrap glen-grid">
      <div class="glen-img">
        <div class="ph glen-ph" role="img" aria-label="Glen Swindell, fractional CRO, Plano TX">
          Glen — working portrait<br><span style="font-size:10px;opacity:0.6;">(replace src)</span>
        </div>
      </div>
      <div class="glen-text">
        <span class="mono-label" style="color:#8A8073;">05 — The person you're hiring</span>
        <h2 class="section-h2 light" style="margin-top:16px;">
          You're not hiring a firm.<br>
          <em class="orange-ital">You're hiring me.</em>
        </h2>
        <p class="glen-body">
          I'm Glen. U.S. Army veteran, ten-plus years leading revenue across enterprise fintech, global payments, and B2B SaaS. I built OrangeCore because the consulting industry sells PowerPoint and calls it strategy. You deserve finished work.
        </p>
        <p class="glen-body" style="margin-top:1rem;">
          When we work together, I'm the one in your CRM. I'm the one writing the playbook. I'm the one on the call with your VP of Sales. No account team, no junior associate, no handoff — just me, the work, and a defined end date.
        </p>
        <div class="glen-tags">
          <span class="glen-tag">U.S. Army Veteran</span>
          <span class="glen-tag">SDVOSB Certified</span>
          <span class="glen-tag">Plano, TX</span>
          <span class="glen-tag">AI-Augmented</span>
        </div>
        <div class="glen-actions">
          <a href="/about/" class="btn-outline-light">More about Glen →</a>
          <a href="/contact/" class="btn-orange">Book a discovery call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER CTA — full orange -->
  <section class="section cta-orange">
    <div class="wrap cta-inner">
      <div>
        <span class="mono-label" style="color:rgba(255,255,255,0.5);">Based in Plano, TX · Serving clients nationwide</span>
        <h2 class="cta-h2">
          Not sure<br>where to start?
        </h2>
        <p class="cta-sub">30 minutes. No pitch deck, no pressure. We'll figure out together if this makes sense — and if it doesn't, you'll hear that too.</p>
      </div>
      <div class="cta-actions">
        <a href="#diagnostic" class="btn-white">Take the diagnostic first</a>
        <a href="/contact/" class="btn-outline-white">Book a call directly →</a>
        <div class="cta-badges">
          <span>SDVOSB Certified</span>
          <span>·</span>
          <span>Veteran Owned</span>
          <span>·</span>
          <span>AI-Augmented Delivery</span>
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
const DIAG_QUESTIONS = [
  { text: "When was the last time your CRM data could survive a board meeting without an apology?", options: [{ label: "Last week — we trust it.", score: 0 },{ label: "Last quarter, give or take.", score: 1 },{ label: "Honestly? Not in recent memory.", score: 2 },{ label: "We don't really use the CRM that way.", score: 3 }] },
  { text: "If we asked your sales lead and marketing lead to define a qualified lead, how close would the answers be?", options: [{ label: "Identical. We've documented it.", score: 0 },{ label: "Close — same intent, different words.", score: 1 },{ label: "They'd argue about it for 20 minutes.", score: 2 },{ label: "They'd disagree on what 'lead' even means.", score: 3 }] },
  { text: "How predictable is next quarter's pipeline right now?", options: [{ label: "Tight forecast, ±5%.", score: 0 },{ label: "Reasonable, ±15%.", score: 1 },{ label: "It's directional at best.", score: 2 },{ label: "We're making decisions on vibes.", score: 3 }] },
  { text: "What's your timeline to fix it?", options: [{ label: "Yesterday — board meeting incoming.", score: 3 },{ label: "Inside the next 30–60 days.", score: 2 },{ label: "This year — when bandwidth allows.", score: 1 },{ label: "Just exploring for now.", score: 0 }] },
];
const RESULTS = [
  { range: [0,3], eyebrow: "Healthy revenue function", h: "Your engine is running. Keep it that way.", body: "Honestly — you may not need us right now. If something specific is bothering you, Foundation will surface it in 10 days. Otherwise, save your money.", rec: { name: "Foundation", note: "Optional · only if a specific signal is off" } },
  { range: [4,7], eyebrow: "Mild misalignment", h: "There's friction, but you can name it.", body: "You know roughly where the leak is. A focused Build — HubSpot rebuild, lead-scoring overhaul, forecast model — handed off in three to four weeks.", rec: { name: "Build", note: "Recommended · $14,500 · 3–4 weeks" } },
  { range: [8,10], eyebrow: "Compounding tax", h: "You're paying for this every month — quietly.", body: "This is where Operate earns its keep. Three months of fractional CRO leadership, hands in the system, board-ready narrative every month.", rec: { name: "Operate", note: "Recommended · $7,500/mo · 3-month minimum" } },
  { range: [11,12], eyebrow: "Active emergency", h: "Skip the diagnostic. Pick up the phone.", body: "What you described is a board-meeting-on-Tuesday situation. Foundation in 10 days, then straight into Operate or Build. Let's talk this week.", rec: { name: "Foundation → Operate", note: "Urgent · combined engagement" } },
];
const state = { step: 0, scores: [] };
function renderStep() {
  const fill = document.getElementById('diag-fill');
  const label = document.getElementById('diag-step-label');
  const host = document.getElementById('diag-questions');
  if (!fill||!label||!host) return;
  fill.style.width = (state.step/DIAG_QUESTIONS.length*100)+'%';
  label.textContent = `Question ${state.step+1} of ${DIAG_QUESTIONS.length}`;
  const q = DIAG_QUESTIONS[state.step];
  host.innerHTML = `<div class="q-num">Q.0${state.step+1}</div><div class="q-text">${q.text}</div><div class="q-opts">${q.options.map((o,i)=>`<button class="q-opt" data-score="${o.score}"><span>${o.label}</span><span class="q-key">${String.fromCharCode(65+i)}</span></button>`).join('')}</div>`;
  host.querySelectorAll('.q-opt').forEach(btn=>{
    btn.addEventListener('click',()=>{
      state.scores.push(parseInt((btn as HTMLElement).dataset.score||'0',10));
      state.step+=1;
      if(state.step>=DIAG_QUESTIONS.length) renderResult(); else renderStep();
    });
  });
}
function renderResult() {
  const total=state.scores.reduce((a,b)=>a+b,0);
  const result=RESULTS.find(r=>total>=r.range[0]&&total<=r.range[1])||RESULTS[1];
  const fill=document.getElementById('diag-fill');
  const label=document.getElementById('diag-step-label');
  const host=document.getElementById('diag-questions');
  if(!fill||!label||!host) return;
  fill.style.width='100%';
  label.textContent=`Result · score ${total}/12`;
  host.innerHTML=`<div class="diag-result"><div class="result-eyebrow">${result.eyebrow}</div><h3 class="result-h">${result.h}</h3><p class="result-body">${result.body}</p><div class="result-rec"><div><div class="result-rec-label">Recommended next step</div><div class="result-rec-name"><b>${result.rec.name}</b> · ${result.rec.note}</div></div><div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px;"><button id="diag-restart" class="q-opt" style="width:auto;padding:10px 16px;">Retake</button><a href="/contact/" class="tier-btn-orange" style="display:inline-flex;align-items:center;padding:10px 18px;border-radius:4px;font-size:14px;font-weight:500;text-decoration:none;">Book a call →</a></div></div></div>`;
  document.getElementById('diag-restart')?.addEventListener('click',()=>{state.step=0;state.scores=[];renderStep();});
}
document.addEventListener('DOMContentLoaded',renderStep);
</script>

<style>
  /* ============================================================
     Design tokens
  ============================================================ */
  :root {
    --paper:     #F4EFE7;
    --paper-2:   #EBE4D7;
    --ink:       #1A1714;
    --ink-2:     #3A332C;
    --ink-3:     #6B6258;
    --rule:      #C9BFAD;
    --orange:    #C2511A;
    --orange-dk: #A3430F;
    --orange-lt: rgba(194,81,26,0.08);
    --mid:       #242018;
    --serif:     'Source Serif 4', Georgia, serif;
    --sans:      'Inter Tight', 'Helvetica Neue', Arial, sans-serif;
    --mono:      'JetBrains Mono', monospace;
  }
  :global(body) { background:var(--paper)!important; color:var(--ink)!important; font-family:var(--sans)!important; }

  /* ============================================================
     Shared utilities
  ============================================================ */
  .wrap { max-width:1240px; margin:0 auto; padding:0 32px; }
  .section { padding:96px 0; }
  .section-dark { background:var(--ink); }
  .section-mid  { background:var(--mid); }
  .mono-label { font-family:var(--mono); font-size:11.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-3); }
  .orange-ital { font-style:italic; color:var(--orange); font-family:var(--serif); }
  .section-h2 { font-family:var(--serif); font-size:clamp(38px,4.8vw,68px); font-weight:600; letter-spacing:-0.025em; line-height:1.02; color:var(--ink); margin-top:14px; }
  .section-h2.light { color:#F4EFE7; }
  .section-sub { font-family:var(--serif); font-size:19px; line-height:1.5; color:var(--ink-2); margin-top:14px; max-width:52ch; }
  .section-sub.light-sub { color:#9A9080; }
  .arr { display:inline-block; transition:transform .2s; }

  /* buttons */
  .btn-orange { display:inline-flex; align-items:center; gap:10px; background:var(--orange); color:#fff; padding:14px 24px; border-radius:4px; font-size:14.5px; font-weight:600; text-decoration:none; border:none; cursor:pointer; transition:background .15s; white-space:nowrap; font-family:var(--sans); }
  .btn-orange:hover { background:var(--orange-dk); }
  .btn-outline-dark { display:inline-flex; align-items:center; gap:10px; background:transparent; color:var(--ink); padding:13px 24px; border-radius:4px; font-size:14.5px; font-weight:500; text-decoration:none; border:2px solid var(--ink); transition:all .15s; white-space:nowrap; font-family:var(--sans); }
  .btn-outline-dark:hover { background:var(--ink); color:var(--paper); }
  .btn-outline-light { display:inline-flex; align-items:center; gap:10px; background:transparent; color:#F4EFE7; padding:13px 24px; border-radius:4px; font-size:14.5px; font-weight:500; text-decoration:none; border:2px solid rgba(244,239,231,0.3); transition:all .15s; white-space:nowrap; font-family:var(--sans); }
  .btn-outline-light:hover { border-color:#F4EFE7; }
  .btn-white { display:inline-flex; align-items:center; gap:10px; background:#fff; color:var(--orange); padding:14px 24px; border-radius:4px; font-size:14.5px; font-weight:600; text-decoration:none; border:none; cursor:pointer; transition:all .15s; white-space:nowrap; font-family:var(--sans); }
  .btn-white:hover { background:#F4EFE7; }
  .btn-outline-white { display:inline-flex; align-items:center; gap:10px; background:transparent; color:#fff; padding:13px 24px; border-radius:4px; font-size:14.5px; font-weight:500; text-decoration:none; border:2px solid rgba(255,255,255,0.4); transition:all .15s; white-space:nowrap; font-family:var(--sans); }
  .btn-outline-white:hover { border-color:#fff; }

  /* placeholder */
  .ph { background:repeating-linear-gradient(135deg,rgba(26,23,20,0.06) 0 2px,transparent 2px 14px),#E2D9C8; border:1px solid var(--rule); display:grid; place-items:center; color:var(--ink-3); font-family:var(--mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; text-align:center; padding:16px; }

  /* ============================================================
     HERO
  ============================================================ */
  .hero { padding:72px 0 0; background:var(--paper); }
  .hero-top { display:flex; align-items:center; gap:24px; margin-bottom:48px; flex-wrap:wrap; }
  .availability { display:inline-flex; align-items:center; gap:8px; font-family:var(--mono); font-size:11.5px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-2); border:1px solid var(--rule); padding:6px 14px; border-radius:999px; }
  .avail-dot { width:7px; height:7px; border-radius:50%; background:var(--orange); flex-shrink:0; animation:pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
