---
import Base from '../../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Glen Swindell",
  "jobTitle": "Fractional Chief Revenue Officer",
  "worksFor": {
    "@type": "Organization",
    "name": "OrangeCore Group",
    "url": "https://orangecoregroup.com"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Plano",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "description": "Glen Swindell is a fractional CRO and RevOps consultant based in Plano, TX. U.S. Army veteran with 10+ years in revenue leadership, payments, and B2B SaaS.",
  "knowsAbout": ["Fractional CRO", "RevOps", "HubSpot", "B2B SaaS", "Fintech", "Payments", "Revenue Leadership"]
};
---

<Base
  title="About Glen Swindell | Fractional CRO & RevOps Consultant | OrangeCore Group"
  description="Glen Swindell is a fractional CRO and RevOps consultant based in Plano, TX. U.S. Army veteran with 10+ years in revenue leadership, payments, and B2B SaaS."
  schema={schema}
>

  <section class="hero">
    <div class="container hero-inner">
      <div class="eyebrow hero-ey">About</div>
      <h1>Glen Swindell — Fractional CRO & RevOps Consultant, Plano TX</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="bio-layout fade-in">
        <div class="bio-text">
          <p class="bio-lead">Glen Swindell is the founder of OrangeCore Group and the person doing the work — not a firm that farms it out.</p>

          <p>He's a fractional Chief Revenue Officer and RevOps consultant based in Plano, TX, focused on B2B SaaS and fintech companies that have outgrown whatever they put together early on. The work is hands-on: pipeline structure, CRM buildouts, go-to-market alignment, sales playbooks, and the systems that make a sales team actually function.</p>

          <p>Glen spent eight years in the U.S. Army (2010–2018). The discipline that comes out of that — systems thinking, accountability, people-first leadership — carries directly into how revenue operations runs. Processes get documented. Timelines get met. The work gets done.</p>

          <p>The fintech and payments background is where things get specific. Past clients include <strong>Verifone</strong> and <strong>Bread Financial</strong> — both enterprise environments with complex sales cycles, compliance-adjacent procurement, and buyers who don't make decisions on a normal B2B timeline. If your buyers include bank risk committees, enterprise procurement in regulated industries, or anyone who needs a vendor security review before signing, that context matters. Most generalist consultants don't have it.</p>

          <p>OrangeCore exists because most fractional consulting is designed to be open-ended. Hourly billing. Scope that drifts. Engagements that never quite finish. The productized approach here is intentional: flat fees, defined deliverables, defined timelines. You know exactly what you're getting before anything starts.</p>

          <p>Currently in delivery: a $15K HubSpot buildout for Sunset Pool Care — full CRM setup, pipeline configuration, and workflow automation for a service business scaling its sales operation. That's the kind of work that ends up on the deliverables list, not a case study three years later.</p>

          <p>OrangeCore is SDVOSB certified (Service-Disabled Veteran-Owned Small Business). For companies working within federal procurement or set-aside contract requirements, that certification is relevant. For everyone else, it's just part of the background.</p>

          <p>Glen also serves on the board of CASA of Denton County — an organization that recruits and trains volunteers to advocate for children in the foster care system. If you're in the DFW area and want to support that work, <a href="https://www.casadentonco.org" target="_blank" rel="noopener">here's the link</a>.</p>

          <p>Based in Plano, TX. Serving clients across DFW and nationally via remote.</p>
        </div>

        <div class="bio-sidebar">
          <div class="headshot-placeholder" role="img" aria-label="Glen Swindell, fractional CRO and RevOps consultant, Plano TX">
            <span class="headshot-initials">GS</span>
            <p class="headshot-note">Photo coming soon</p>
          </div>

          <div class="sidebar-facts">
            <div class="fact-item">
              <p class="fact-label">Location</p>
              <p class="fact-val">Plano, TX · DFW</p>
            </div>
            <div class="fact-item">
              <p class="fact-label">Focus</p>
              <p class="fact-val">B2B SaaS, Fintech, Payments</p>
            </div>
            <div class="fact-item">
              <p class="fact-label">Experience</p>
              <p class="fact-val">10+ years revenue leadership</p>
            </div>
            <div class="fact-item">
              <p class="fact-label">Military</p>
              <p class="fact-val">U.S. Army 2010–2018</p>
            </div>
            <div class="fact-item">
              <p class="fact-label">Certification</p>
              <p class="fact-val">SDVOSB Certified</p>
            </div>
            <div class="fact-item">
              <p class="fact-label">CRMs</p>
              <p class="fact-val">HubSpot · Salesforce · Pipedrive</p>
            </div>
          </div>

          <div class="sidebar-clients">
            <p class="fact-label">Past clients include</p>
            <p class="client-name">Verifone</p>
            <p class="client-name">Bread Financial</p>
            <p class="client-name">Sunset Pool Care</p>
          </div>

          <div class="sidebar-badges">
            <span class="badge">SDVOSB Certified</span>
            <span class="badge">Veteran Owned</span>
            <span class="badge">AI-Augmented</span>
          </div>
        </div>
      </div>

      <div class="why-section fade-in">
        <div class="section-header">
          <p class="eyebrow">Why OrangeCore</p>
          <h2>The honest version of why this firm exists.</h2>
        </div>
        <div class="why-grid">
          <div class="why-item">
            <h3>Generalists are everywhere.</h3>
            <p>Most fractional consultants will work with any company in any industry. That breadth is also a ceiling — they can give you advice, but not the kind of advice that comes from actually knowing how interchange rates affect your sales cycle or how enterprise financial services procurement works.</p>
          </div>
          <div class="why-item">
            <h3>Open-ended engagements don't serve anyone well.</h3>
            <p>The hourly billing model creates the wrong incentives. When there's no defined endpoint, projects drift. Clients get comfortable with "progress." The consultant stays engaged longer than they should. OrangeCore is built around the opposite: defined scope, defined deliverables, defined end.</p>
          </div>
          <div class="why-item">
            <h3>AI changes what's possible at this price point.</h3>
            <p>Every engagement is AI-augmented. That's not a sales line — it's the reason a two-person firm can produce the quality and volume of work that would otherwise require a team. Faster delivery, more thorough documentation, better analysis. The thinking is still human. The output is more consistent.</p>
          </div>
        </div>
      </div>

      <div class="footer-cta-banner fade-in">
        <p class="eyebrow">Based in Plano, TX · Serving DFW and clients nationwide</p>
        <h2>Want to work together?</h2>
        <p>Book a 30-minute discovery call. We'll figure out if there's a fit — and if there isn't, you'll hear that clearly too.</p>
        <a href="/contact/" class="btn-primary">Book a discovery call</a>
      </div>

    </div>
  </section>
</Base>

<style>
.hero{background:var(--charcoal);padding:4rem 0 3rem;text-align:center;}
.hero-ey{color:var(--orange);border:1px solid rgba(232,97,10,0.4);padding:4px 14px;border-radius:2px;}
.hero h1{font-size:clamp(1.6rem,4vw,2.6rem);font-weight:700;color:#fff;line-height:1.2;letter-spacing:-0.03em;max-width:700px;margin:1rem auto 0;}
.bio-layout{display:grid;grid-template-columns:1fr 300px;gap:4rem;margin-bottom:5rem;align-items:start;}
.bio-text p{font-size:15.5px;line-height:1.8;color:var(--charcoal);margin-bottom:1.25rem;}
.bio-text p:last-child{margin-bottom:0;}
.bio-lead{font-size:18px !important;font-weight:500;color:var(--charcoal) !important;}
.bio-text a{color:var(--orange);text-decoration:underline;}
.bio-text strong{font-weight:600;}
.headshot-placeholder{background:var(--warm-gray);border:1px solid var(--border);border-radius:8px;aspect-ratio:3/4;display:flex;flex-direction:column;align-items:center;justify-content:center;margin-bottom:1.5rem;}
.headshot-initials{font-family:var(--font-serif);font-size:3rem;font-weight:700;color:var(--mid-gray);}
.headshot-note{font-size:12px;color:var(--mid-gray);margin-top:0.5rem;}
.sidebar-facts{border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:1.25rem;}
.fact-item{padding:0.75rem 1rem;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;}
.fact-item:last-child{border-bottom:none;}
.fact-label{font-size:11px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-gray);}
.fact-val{font-size:13px;color:var(--charcoal);font-weight:400;}
.sidebar-clients{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:1rem;margin-bottom:1.25rem;}
.client-name{font-family:var(--font-serif);font-size:15px;font-weight:500;color:var(--charcoal);padding:4px 0;}
.sidebar-badges{display:flex;flex-direction:column;gap:0.4rem;}
.badge{font-size:10px;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;border:1px solid rgba(232,97,10,0.4);color:var(--orange);padding:4px 10px;border-radius:2px;text-align:center;}
.why-section{margin-bottom:4rem;}
.why-section h2{font-size:clamp(1.5rem,3vw,2rem);margin:0.5rem 0 2.5rem;}
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem 3rem;}
.why-item h3{font-family:var(--font-serif);font-size:1.1rem;font-weight:700;color:var(--charcoal);margin-bottom:0.5rem;}
.why-item p{font-size:13.5px;color:var(--mid-gray);line-height:1.65;}
@media(max-width:768px){.bio-layout{grid-template-columns:1fr;}.bio-sidebar{order:-1;}.why-grid{grid-template-columns:1fr;}}
</style>
